# Variables de entorno — nunca commitear
.env
.env.*
*.env
app/.env.local
app/.env.*.local

# Scripts temporales de debugging (pueden contener credenciales)
query_*.js
pw_*.js
insert_*.js
migrate_*.js
seed_*.js
fix_*.js

# Directorios temporales
.tmp/
temp/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.vscode/settings.json
.idea/

# Node (scripts raíz o herramientas auxiliares)
node_modules/

# Backups de limpieza de datos de prueba (dumps con datos, no versionar)
scripts/cleanup-mbtest/backups/

# Logs
*.log
npm-debug.log*

# Graphify cache — may contain source code snapshots with credentials
graphify-out/cache/
# Graphify — estado generado volátil (no versionar)
graphify-out/manifest.json
graphify-out/.graphify_uncached.txt

# Vercel — link local del proyecto (el deploy usa la integración de GitHub)
.vercel/

# Artefactos de sesiones de brainstorming/SDD (locales)
.superpowers/brainstorm/
.superpowers/sdd/

# Capturas de pantalla en la raíz de app/ (NO afecta assets de app/public/)
app/*.png

# Scripts de prueba locales (puppeteer/dev) en la raíz de app/
app/test-*.cjs
